{
  "name": "@ismail-elkorchi/xml-parser",
  "version": "0.1.1",
  "type": "module",
  "sideEffects": false,
  "description": "Namespace-aware XML parser with bounded resources and no runtime dependencies.",
  "engines": {
    "node": ">=20.0.0",
    "npm": ">=10.0.0"
  },
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/Ismail-elkorchi/xml-parser.git"
  },
  "publishConfig": {
    "access": "public"
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "main": "./dist/mod.js",
  "types": "./dist/mod.d.ts",
  "exports": {
    ".": {
      "types": "./dist/mod.d.ts",
      "import": "./dist/mod.js"
    }
  },
  "scripts": {
    "build": "node scripts/build/build.mjs",
    "deps:outdated": "npm outdated",
    "examples:run": "npm run build && node examples/run-all.mjs",
    "check:fast": "npm run lint && npm run typecheck && npm test && npm run typecheck:jsr && npm run docs:lint:jsr && npm run docs:test:jsr && npm run examples:run",
    "docs:lint:jsr": "deno doc --lint jsr/mod.ts",
    "docs:test:jsr": "deno test --doc jsr/mod.ts",
    "lint": "eslint . --max-warnings=0",
    "smoke:all": "npm run smoke:node && npm run smoke:deno && npm run smoke:bun",
    "smoke:browser": "npm run build && node scripts/smoke/runtime-browser-smoke.mjs --report=reports/browser-smoke.json",
    "smoke:bun": "npm run build && bun scripts/smoke/runtime-smoke.mjs",
    "smoke:deno": "npm run build && deno run --allow-read scripts/smoke/runtime-smoke.mjs",
    "smoke:node": "npm run build && node scripts/smoke/runtime-smoke.mjs",
    "qualification:ci": "node scripts/qualification/run.mjs",
    "qualification:release": "node scripts/qualification/run.mjs --release",
    "test": "npm run build && node --test && npm run test:types",
    "test:fuzz": "npm run build && node scripts/qualification/fuzz.mjs",
    "test:package": "npm run build && node scripts/qualification/package.mjs",
    "test:types": "tsc -p tsconfig.type-tests.json",
    "typecheck": "tsc --noEmit -p tsconfig.build.json",
    "typecheck:jsr": "deno check jsr/mod.ts"
  },
  "devDependencies": {
    "@eslint/js": "10.0.1",
    "eslint": "10.7.0",
    "eslint-plugin-boundaries": "7.1.0",
    "playwright": "1.61.1",
    "typescript": "6.0.3",
    "typescript-eslint": "8.65.0"
  }
}
