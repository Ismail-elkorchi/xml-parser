{
  "name": "@ismail-elkorchi/xml-parser",
  "version": "0.1.1",
  "type": "module",
  "description": "Deterministic, agent-first XML parser.",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/Ismail-elkorchi/xml-parser.git"
  },
  "publishConfig": {
    "access": "public"
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "main": "./dist/mod.js",
  "types": "./dist/mod.d.ts",
  "exports": {
    ".": {
      "types": "./dist/mod.d.ts",
      "import": "./dist/mod.js"
    }
  },
  "scripts": {
    "build": "tsc -p tsconfig.build.json",
    "eval:ci": "node scripts/quality/eval/run-eval.mjs --profile=ci",
    "eval:release": "node scripts/quality/eval/run-eval.mjs --profile=release",
    "deps:freshness": "npm outdated || true",
    "examples:run": "npm run build && node examples/run-all.mjs",
    "check:fast": "npm run lint && npm run typecheck && npm test && npm run examples:run",
    "docs:lint:jsr": "deno doc --lint --sloppy-imports jsr/mod.ts",
    "docs:test:jsr": "deno test --doc --no-check --sloppy-imports jsr/mod.ts",
    "lint": "eslint . --max-warnings=0",
    "oracle:xmllint": "npm run build && node scripts/dev/run-xmllint-oracle-compare.mjs",
    "smoke:all": "npm run smoke:node && npm run smoke:deno && npm run smoke:bun",
    "smoke:browser": "npm run build && node scripts/smoke/runtime-browser-smoke.mjs --report=reports/browser-smoke.json",
    "smoke:bun": "npm run build && bun scripts/smoke/runtime-smoke.mjs",
    "smoke:deno": "npm run build && deno run --allow-read scripts/smoke/runtime-smoke.mjs",
    "smoke:node": "npm run build && node scripts/smoke/runtime-smoke.mjs",
    "mutation:pilot": "npm run build && node scripts/mutation/run-pilot.mjs --config=scripts/mutation/pilot-config.json --out=docs/reference/mutation-pilot-report.json",
    "test": "npm run build && node --test test/**/*.test.mjs",
    "test:fuzz": "npm run build && node scripts/quality/eval/check-security-adversarial.mjs",
    "typecheck": "tsc --noEmit -p tsconfig.build.json"
  },
  "dependencies": {},
  "devDependencies": {
    "@eslint/js": "9.39.3",
    "eslint": "9.39.3",
    "eslint-import-resolver-typescript": "4.4.4",
    "eslint-plugin-boundaries": "5.4.0",
    "eslint-plugin-import": "2.32.0",
    "playwright": "1.58.2",
    "typescript": "5.9.3",
    "typescript-eslint": "8.56.1"
  }
}
